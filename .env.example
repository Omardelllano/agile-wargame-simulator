# =============================================================================
# AGILE WARGAME SIMULATOR — Environment Configuration
# =============================================================================
# 1. Copy this file:   cp .env.example .env   (Windows: copy .env.example .env)
# 2. Fill in the keys for the provider(s) you want to use
# 3. NEVER commit .env to git — it is already in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# DEFAULT PROVIDER
# Options: mock | gemini-free | deepseek | openai
# mock requires no API key and is the default for development and CI
# -----------------------------------------------------------------------------
DEFAULT_PROVIDER=mock

# -----------------------------------------------------------------------------
# LLM PROVIDER API KEYS
# Only the key for your chosen provider is required.
# Leave the others empty — they will not be loaded.
# -----------------------------------------------------------------------------

# Google Gemini Free Tier
# Get your free key at: https://aistudio.google.com/app/apikey
# Free quota: 1,500 requests/day, 1M tokens/day — enough for many simulations
# Recommended model: gemini-2.0-flash
GEMINI_API_KEY=

# DeepSeek API (~$0.03-0.05 USD per sprint simulation — extremely cheap)
# Get your key at: https://platform.deepseek.com/api-keys
# Recommended model: deepseek-chat (DeepSeek-V3)
DEEPSEEK_API_KEY=

# OpenAI (fallback — more expensive, ~$0.80 USD per sprint simulation)
# Get your key at: https://platform.openai.com/api-keys
# Recommended model: gpt-4o-mini
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# INFRASTRUCTURE
# These defaults work with docker compose up out of the box.
# Only change if you are running services on non-default ports.
# -----------------------------------------------------------------------------

# ChromaDB vector store
CHROMA_HOST=localhost
CHROMA_PORT=8001

# SQLite database path (relative to project root)
# For Docker: use /app/output/wargame.db
DATABASE_URL=sqlite:///./output/wargame.db

# -----------------------------------------------------------------------------
# SIMULATION DEFAULTS
# These are overridden by CLI flags when provided.
# Example: --sprints 4 overrides DEFAULT_SPRINTS
# -----------------------------------------------------------------------------
DEFAULT_SPRINTS=8
DEFAULT_TURNS_PER_SPRINT=10
DEFAULT_SCENARIO=seeds/etp/

# -----------------------------------------------------------------------------
# DASHBOARD
# -----------------------------------------------------------------------------
DASHBOARD_PORT=8000

# -----------------------------------------------------------------------------
# OPTIONAL: Override default model per provider
# Uncomment and set if you want a specific model version.
# If left empty, each provider uses its recommended default.
# -----------------------------------------------------------------------------
# GEMINI_MODEL=gemini-2.0-flash
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# DEVELOPMENT FLAGS
# Set LOG_LEVEL=DEBUG to see full prompt/response logs for each agent turn
# Set GROUNDING_STRICT=false to warn instead of raise on hallucinated story IDs
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
GROUNDING_STRICT=true
